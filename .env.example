# Copy this file to `.env` (which is git-ignored) and paste your free Gemini keys.
# Comma-separated, no quotes needed. Get keys at https://aistudio.google.com/apikey
# (one per Google account). Jarvis rotates across them + across models automatically.

JARVIS_GEMINI_KEYS=key_one_here,key_two_here,key_three_here,key_four_here,key_five_here

# Control Jarvis from your phone (free) — see README "Phone control":
#   1. In Telegram, message @BotFather → /newbot → copy the token below
#   2. Start Jarvis, message your new bot once; it replies with your chat id
#   3. Put that id below and restart
# JARVIS_TELEGRAM_TOKEN=123456:ABC-your-bot-token
# JARVIS_TELEGRAM_CHAT_ID=123456789

# Optional overrides:
# JARVIS_MIC_INDEX=3
# JARVIS_CAM_INDEX=0            # webcam for visual presence (default 0)
# JARVIS_PRESENCE=1            # 0 to disable the always-on webcam awareness
# JARVIS_POSTURE_MINUTES=0     # >0 = Gemini posture check every N min (uses quota)
# JARVIS_AWAY_PAUSE=0          # 1 = pause media when you leave, resume when you return
# JARVIS_AWAY_LOCK_SECONDS=0   # >0 = lock the PC after N seconds away (0 = never)
# JARVIS_AWAY_ALERT=0          # 1 = text a webcam photo to your phone on desk movement while away
# JARVIS_GEMINI_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite
# JARVIS_HUD_PORT=8765
