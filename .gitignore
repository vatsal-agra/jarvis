# ── Secrets — NEVER commit ────────────────────────────────────────────────
jarvis_keys.txt
.env
.env.*
!.env.example
*.key
secrets*.py

# ── Personal long-term memory (private facts about the user) ──────────────
jarvis_memory.json
jarvis_reminders.json
jarvis_routines.json
jarvis_usage.json
jarvis_schedule.json
jarvis_skills/

# ── Local Chrome profile / login session (cookies, tokens) ────────────────
.jarvis_chrome_profile/

# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
*.egg-info/
.pytest_cache/

# ── Audio / temp artifacts ────────────────────────────────────────────────
*.mp3
*.wav
*.tmp
tmp/
temp/

# ── OS / editor cruft ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
